{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/KeikaJames/Efferva/schemas/sac.v1.metadata.schema.json",
  "title": "SAC v1 Metadata (exportable)",
  "description": "Exportable SAC metadata. No secret material. Safe to share.",
  "type": "object",
  "required": ["version", "sac_id", "created_at", "root_key", "memory_root", "permissions", "derived_agents"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "enum": ["1"] },
    "sac_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "root_key": {
      "type": "object",
      "required": ["key_id", "created_at", "rotated_at"],
      "additionalProperties": false,
      "properties": {
        "key_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "rotated_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "memory_root": {
      "type": "object",
      "required": ["memory_id", "reference", "created_at"],
      "additionalProperties": false,
      "properties": {
        "memory_id": { "type": "string" },
        "reference": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["allowed_operations", "financial_daily_limit", "financial_single_tx_limit", "actions_require_confirmation"],
      "additionalProperties": false,
      "properties": {
        "allowed_operations": { "type": "array", "items": { "type": "string" } },
        "financial_daily_limit": { "type": ["number", "null"] },
        "financial_single_tx_limit": { "type": ["number", "null"] },
        "actions_require_confirmation": { "type": "array", "items": { "type": "string" } }
      }
    },
    "derived_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "purpose", "created_at", "parent_sac_id", "derived_key_id", "permissions", "revoked", "revoked_at"],
        "additionalProperties": false,
        "properties": {
          "agent_id": { "type": "string" },
          "purpose": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "parent_sac_id": { "type": "string" },
          "derived_key_id": { "type": "string" },
          "permissions": {
            "type": "object",
            "required": ["allowed_operations", "financial_daily_limit", "financial_single_tx_limit", "actions_require_confirmation"],
            "additionalProperties": false,
            "properties": {
              "allowed_operations": { "type": "array", "items": { "type": "string" } },
              "financial_daily_limit": { "type": ["number", "null"] },
              "financial_single_tx_limit": { "type": ["number", "null"] },
              "actions_require_confirmation": { "type": "array", "items": { "type": "string" } }
            }
          },
          "revoked": { "type": "boolean" },
          "revoked_at": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "recovery_method": { "type": ["string", "null"] }
  }
}
